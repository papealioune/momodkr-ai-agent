# Cloudflare R2 credentials -- dedicated momodkr-data bucket (Path B, 2026-06-01)
# Generate at Cloudflare dashboard > R2 > Manage R2 API Tokens
#   Permissions: Object Read & Write
#   Specify bucket(s): momodkr-data only
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Optional overrides (defaults shown)
# R2_ENDPOINT_URL=https://9507330fe5a8c228ea49f6e5c6c6b659.r2.cloudflarestorage.com
# R2_BUCKET_NAME=momodkr-data
# MOMODKR_R2_PREFIX=                  # default empty; the whole bucket is the project namespace

# OPTIONAL: separate moleapp bucket creds for the one-shot cross-bucket
# funding pull (`--pull-moleapp-funding`). Leave unset for the default
# Binance-Vision-only funding path.
# R2_MOLEAPP_ACCESS_KEY_ID=
# R2_MOLEAPP_SECRET_ACCESS_KEY=

# Weights & Biases (optional, for training runs in later phases)
# WANDB_API_KEY=

# Akeyless (production secrets, used in Phase 8+)
# AKEYLESS_TOKEN=

# Hyperliquid API agent wallet (production only, Phase 8+)
# HL_API_AGENT_PRIVATE_KEY=
